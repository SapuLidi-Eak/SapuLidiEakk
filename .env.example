# ==============================
# DISCORD BOT CONFIG
# ==============================
DISCORD_TOKEN=your_discord_bot_token_here
CLIENT_ID=your_discord_application_id_here
GUILD_ID=your_discord_server_id_here

# ==============================
# ROLE CONFIG
# ==============================
# ID role premium yang akan diberikan setelah redeem key berhasil
PREMIUM_ROLE_ID=your_premium_role_id_here

# ==============================
# WEBSITE API CONFIG
# ==============================
# URL website kamu (tanpa trailing slash)
# Contoh: https://kingvypers.up.railway.app
WEBSITE_URL=https://your-website-url-here.com

# Secret untuk bot endpoint /api/reset-hwid
# Harus sama dengan BOT_SECRET di .env website kamu
BOT_SECRET=your_bot_secret_here

# ==============================
# SCRIPT LOADER (Bisa tambah s/d 10 script)
# ==============================
LOADER_SCRIPT=loadstring(game:HttpGet("https://your-website-url-here.com/api/loader"))()
LOADER_SCRIPT_2=loadstring(game:HttpGet("https://your-website-url-here.com/api/loader2"))()

# ==============================
# RESTRICTION (Opsional)
# ==============================
# ID Role yang diizinkan untuk memakai bot ini (Biarkan kosong jika semua bisa pakai)
ALLOWED_ROLE_ID=
